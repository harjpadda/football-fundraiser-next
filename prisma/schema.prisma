datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("USER")
  createdAt    DateTime @default(now())

  // ✅ NEW: user belongs to one team
  teamId Int?
  team   Team? @relation(fields: [teamId], references: [id])

  orders Order[]

  // ✅ Required for NextAuth/Auth.js Prisma adapter
  accounts Account[]
  sessions Session[]
}

model Team {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  currentWeekId Int?
  currentWeek   Week? @relation(fields: [currentWeekId], references: [id])

  createdAt DateTime @default(now())
  orders    Order[]

  users User[] // ✅ add this
}

model Week {
  id              Int              @id @default(autoincrement())
  label           String
  isActive        Boolean          @default(true)
  fixtures        Fixture[]
  orders          Order[]
  linePredictions LinePrediction[]
  currentTeams    Team[] // ⭐ Teams using this week
  createdAt       DateTime         @default(now())
}

model Fixture {
  id       Int              @id @default(autoincrement())
  weekId   Int
  week     Week             @relation(fields: [weekId], references: [id])
  homeTeam String
  awayTeam String
  kickoff  DateTime?
  position Int
  result   String? // ✅ "HOME" | "DRAW" | "AWAY" (or null if not set yet)
  lines    LinePrediction[]
}

model Order {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  teamId          Int
  team            Team             @relation(fields: [teamId], references: [id])
  weekId          Int
  week            Week             @relation(fields: [weekId], references: [id])
  lineCount       Int
  amountPence     Int
  stripeSessionId String           @unique
  paid            Boolean          @default(false)
  createdAt       DateTime         @default(now())
  lines           LinePrediction[]
}

model LinePrediction {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  fixtureId Int
  fixture   Fixture @relation(fields: [fixtureId], references: [id])

  weekId Int
  week   Week @relation(fields: [weekId], references: [id])

  lineIndex Int
  result    String
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
